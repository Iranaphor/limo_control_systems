# Robot-specific configuration
ROBOT_NAME=LM-001535

# Path to map file inside the limo_drivers container (optional, has a default)
# MAP_YAML_FILE=/opt/ros/lcas/install/limo_navigation/share/limo_navigation/maps/simple_map.yaml

# Default tmule session to launch
TMULE_FILE=/home/ros/ros2_ws/src/local/my_limo/tmule/toponav.tmule.yaml

# ROS domain ID (shared across containers)
# ROS_DOMAIN_ID=0

RVIZ_CONFIG="/workspaces/limo_ros2/src/custom_packages/my_limo/config/display.rviz2.yaml"
